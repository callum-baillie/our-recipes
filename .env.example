# Use a host-mounted path in Docker/Unraid, never a path inside a disposable container layer.
# SQLite, recipe images, and future generated media remain below this directory.
DATA_DIR=./data
DATABASE_URL=./data/our-recipes.db
# Required in production: a unique secret of at least 32 characters.
COOKIE_SECRET=replace-with-a-long-random-secret-before-production
# Set this to the exact browser-visible origin. Camera scanning requires trusted HTTPS.
APP_ORIGIN=https://recipes.tower
# Optional comma-separated additional exact origins for a trusted reverse proxy.
TRUSTED_ORIGINS=
# Optional private bearer token for GET /api/integrations/homepage/v1/summary.
# Generate a unique high-entropy value and share it only with the internal Homepage service.
HOMEPAGE_INTEGRATION_TOKEN=
# Scheduled local backup interval and how long completed bundles remain in DATA_DIR/backups.
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
# Optional. OpenAI is server-only and invoked only after a household member explicitly requests a review or image.
# Production reads this environment variable only. Do not copy the development-only .api_keys file into a container.
OPENAI_API_KEY=

# Open Food Facts exact product reads are enabled by default and need no credential.
OPEN_FOOD_FACTS_ENABLED=true
OPEN_FOOD_FACTS_BASE_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_API_VERSION=v3.6
OPEN_FOOD_FACTS_USER_AGENT=Bord/1.0.0-rc.1 (https://github.com/callum-baillie/bord)
OPEN_FOOD_FACTS_TIMEOUT_MS=5000
OPEN_FOOD_FACTS_PRODUCT_RPM=12

# USDA FoodData Central search/detail is enabled only when this server-side key is present.
USDA_FDC_ENABLED=true
USDA_FDC_API_KEY=
USDA_FDC_BASE_URL=https://api.nal.usda.gov/fdc/v1
USDA_FDC_TIMEOUT_MS=8000
USDA_FDC_REQUESTS_PER_HOUR=900
USDA_FDC_LOW_QUOTA_REMAINING=100

# Provider-aware cache defaults; values are seconds except the row cap.
FOOD_DATA_EXACT_TTL_SECONDS=604800
FOOD_DATA_SEARCH_TTL_SECONDS=900
FOOD_DATA_NEGATIVE_TTL_SECONDS=900
FOOD_DATA_TRANSIENT_TTL_SECONDS=30
FOOD_DATA_EXACT_STALE_SECONDS=2592000
FOOD_DATA_SEARCH_STALE_SECONDS=86400
FOOD_DATA_CACHE_ROW_CAP=5000

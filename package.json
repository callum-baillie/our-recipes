{
  "name": "our-recipes",
  "version": "0.1.0-beta.9",
  "private": true,
  "description": "A self-hosted household recipe manager for a local Unraid deployment.",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:ocr:smoke": "vitest run --project integration tests/integration/local-ocr-smoke.test.ts",
    "test:e2e": "tsx scripts/prepare-e2e.ts && playwright test tests/e2e/setup.spec.ts",
    "test:a11y": "tsx scripts/prepare-e2e.ts && playwright test tests/e2e/a11y.spec.ts",
    "test:release-quality": "tsx scripts/prepare-e2e.ts && playwright test tests/e2e/release-quality.spec.ts && vitest run --project integration tests/integration/recipe-performance.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:check": "tsx scripts/check-db.ts",
    "test:docker": "node scripts/docker-smoke.mjs",
    "openapi:validate": "redocly lint docs/openapi.yaml",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm openapi:validate && pnpm build"
  },
  "dependencies": {
    "@discourse/heic": "1.0.0",
    "@hookform/resolvers": "5.4.0",
    "@radix-ui/react-slot": "1.3.0",
    "@tesseract.js-data/eng": "1.0.0",
    "better-sqlite3": "12.11.1",
    "cheerio": "1.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "openai": "6.46.0",
    "pdfjs-dist": "6.1.200",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "server-only": "0.0.1",
    "sharp": "0.35.3",
    "tailwind-merge": "3.6.0",
    "tar": "7.5.20",
    "tesseract.js": "7.0.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@redocly/cli": "2.38.0",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tailwindcss": "4.3.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
